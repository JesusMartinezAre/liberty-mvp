# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── Firebase (frontend) ───────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_DATABASE_URL — intentionally omitted; only needed for Realtime Database (not Firestore)
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123

# ── Cloudinary ────────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD=your_cloud_name
VITE_CLOUDINARY_PRESET=your_upload_preset

# ── EmailJS ───────────────────────────────────────────────────────────────────
VITE_EMAILJS_SERVICE=service_xxxxxxx
VITE_EMAILJS_TEMPLATE=template_xxxxxxx
VITE_EMAILJS_KEY=your_public_key
VITE_NOTIFY_EMAIL=notify@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
VITE_CORRECT_PIN=0000

# ── Netlify Functions — Firebase Admin ────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Netlify Functions — SCIM ──────────────────────────────────────────────────
SCIM_AUTH_TOKEN=your_scim_token
SCIM_AUTH_TOKEN_LIBERTY=your_scim_liberty_token   # set in Netlify dashboard for production

# ── Netlify Functions — Okta OIDC ─────────────────────────────────────────────
OKTA_ISSUER=https://your_okta_domain/oauth2/default
OKTA_AUDIENCE=api://default

# ── Netlify Functions — Session JWT ───────────────────────────────────────────
SESSION_JWT_SECRET=a_long_random_secret_at_least_32_characters
SESSION_JWT_ISSUER=app://your_app_name

# ── Netlify Functions — Microsoft Entra SAML ─────────────────────────────────
ENTRA_TENANT_ID=your_tenant_guid
ENTRA_SP_ENTITY_ID=https://your_netlify_site.netlify.app
ENTRA_ACS_URL=https://your_netlify_site.netlify.app/api/auth/saml/callback
ENTRA_IDP_CERT=your_base64_certificate_without_headers

# ── UNUSED / DEPRECATED ───────────────────────────────────────────────────────
# Variables listed here are no longer referenced by the codebase.
# Commented out for safety; remove only after confirming they are not needed.
